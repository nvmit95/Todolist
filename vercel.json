{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/backend/(.*)",
      "destination": "/api/bridge?path=$1"
    },
    {
      "source": "/((?!backend/|api/).*)",
      "destination": "/index.html"
    }
  ]
}
